{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "watchPatterns": [
      "src/**",
      "prisma/**",
      "package.json",
      "package-lock.json",
      "next.config.ts",
      "railway.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10,
    "overlapSeconds": 30,
    "drainingSeconds": 30
  }
}