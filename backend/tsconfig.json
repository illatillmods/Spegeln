{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "../src/*"
      ],
      "next/cache": [
        "./src/shims/next-cache.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "../src/lib/**/*.ts"
  ]
}