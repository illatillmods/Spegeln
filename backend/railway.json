{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build",
    "watchPatterns": [
      "src/**",
      "scripts/**",
      "package.json",
      "tsconfig.json",
      "railway.json",
      "../src/lib/**",
      "../prisma/**"
    ]
  },
  "deploy": {
    "startCommand": "npm run start",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10,
    "overlapSeconds": 30,
    "drainingSeconds": 30
  }
}