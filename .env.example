# Railway Postgres connection string
DATABASE_URL="postgresql://postgres:PASSWORD@switchyard.proxy.rlwy.net:PORT/railway"

# Vercel production URL for metadata, canonical links and public app references
NEXT_PUBLIC_APP_URL="https://spegeln.vercel.app"

# Session signing for auth cookies
AUTH_SESSION_SECRET="replace-with-a-long-random-secret"


# Optional deployment hints picked up automatically by the health endpoint
VERCEL_PROJECT_PRODUCTION_URL="spegeln.vercel.app"
RAILWAY_PUBLIC_DOMAIN=""
RAILWAY_ENVIRONMENT_NAME="production"

# Stripe API keys (lägg in riktiga i Railway/Vercel dashboard, EJ i repo)
STRIPE_SECRET_KEY="sk_live_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_PRICE_PLUS_MONTHLY="price_xxx"
STRIPE_PRICE_PRO_MONTHLY="price_xxx"
STRIPE_PRICE_USAGE_MASS_APPEAL="price_xxx"
STRIPE_PRICE_USAGE_AI_ANALYSIS="price_xxx"
STRIPE_PRICE_API_PARTNER="price_xxx"
STRIPE_PRICE_DONATION="price_xxx"

# OAuth för social inloggning
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# SMTP för verkliga myndighetsutskick till registratorer och e-postgateways
MASS_APPEALS_SMTP_HOST="smtp.example.com"
MASS_APPEALS_SMTP_PORT="587"
MASS_APPEALS_SMTP_SECURE="false"
MASS_APPEALS_SMTP_USER="mailer@example.com"
MASS_APPEALS_SMTP_PASS="smtp_password"
MASS_APPEALS_FROM_EMAIL="Spegeln <mailer@example.com>"

# Secure mailbox-workflow för mottagare som kräver separat transport
MASS_APPEALS_SECURE_MAILBOX_WEBHOOK_URL="https://secure-mailbox.example.com/api/messages"
MASS_APPEALS_SECURE_MAILBOX_API_KEY="secure_mailbox_api_key"

# Next.js -> FastAPI worker bridge för tax optimization och NLP-jobb
AI_WORKER_URL="https://spegeln-ai-worker.railway.app"
AI_WORKER_SHARED_SECRET="shared_secret_between_next_and_worker"

# FastAPI worker -> modellprovider (OpenAI-kompatibel endpoint eller intern gateway)
AI_PROVIDER_API_URL="https://api.openai.com/v1"
AI_PROVIDER_API_KEY="sk_xxx"
AI_CHAT_MODEL="gpt-5-mini"